#  MAIN WINDOW (The Uni    def _run_in_frame(self, js):
        """Executa JS no iframe do módulo ativo."""
        safe_js = js.replace('`', '\\`')
        full_js = f"""(function(){{ var f=document.getElementById('main-frame'); if(f&&f.contentWindow) f.contentWindow.eval({json.dumps(safe_js)}); }})()"""
        self.web.page().runJavaScript(full_js)

    def _inject_dashboard_full(self):
        """Injeta dados completos no dashboard."""
        import datetime as dt_lib
        prods = self.dm.get_products(); sales = self.dm.get_sales(); now = datetime.now()
        td = sum(s.get("total",0) for s in sales if s.get("date","")[:10]==now.strftime("%Y-%m-%d") and s.get("status") != "cancelada")
        mo = sum(s.get("total",0) for s in sales if s.get("date","")[:7]==now.strftime("%Y-%m") and s.get("status") != "cancelada")
        alerts = [p for p in prods if p.get("stock",0)<=p.get("min_stock",0)]
        recent = sorted(sales,key=lambda x:x.get("date",""),reverse=True)[:10]

        table_html = ""
        for s in recent:
            items_str = str(len(s.get("items",[])))
            val_str = fmtR(s.get("total",0))
            c_name = s.get("customer_name","--")
            dt_str = s.get("date","")[:16].replace("T", " ")
            status = "Cancelada" if s.get("status") == "cancelada" else "Concluido"
            st_color = "bg-red-500/20 text-red-400" if status == "Cancelada" else "bg-emerald-500/20 text-emerald-400"
            table_html += f'<tr class="hover:bg-slate-700/30 transition-colors"><td class="px-6 py-4 font-bold text-[#FF6B35]">{s.get("id","")[:8]}</td><td class="px-6 py-4 text-sm text-slate-400">{dt_str}</td><td class="px-6 py-4 text-sm">{c_name}</td><td class="px-6 py-4 text-sm">{items_str} prod.</td><td class="px-6 py-4"><span class="inline-block px-2 py-1 rounded-full text-[10px] font-bold {st_color} uppercase">{status}</span></td><td class="px-6 py-4 text-right font-bold text-[#FF6B35]">{val_str}</td></tr>'

        bars_html = ""; labels_html = ""
        today = dt_lib.date.today()
        max_day = max((sum(s.get("total",0) for s in sales if s.get("date","")[:10] == (today - dt_lib.timedelta(days=i)).strftime("%Y-%m-%d") and s.get("status") != "cancelada") for i in range(7)), default=1)
        for i in range(6, -1, -1):
            d = today - dt_lib.timedelta(days=i)
            d_str = d.strftime("%Y-%m-%d")
            total = sum(s.get("total",0) for s in sales if s.get("date","")[:10] == d_str and s.get("status") != "cancelada")
            pct = max(8, int((total / (max_day or 1)) * 85))
            s_lbl = d.strftime("%a")
            bars_html += f'<div class="w-full bg-[#FF6B35]/10 rounded-t-sm flex flex-col justify-end" style="height:{pct}%;"><div class="w-full bg-[#FF6B35] rounded-t-sm transition-all hover:bg-orange-400 relative group" style="height:100%"><div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-slate-900 text-white text-[10px] px-2 py-1 rounded whitespace-nowrap opacity-0 group-hover:opacity-100 z-10">R${int(total)}</div></div></div>'
            labels_html += f'<span class="text-[10px] text-slate-400">{s_lbl}</span>'

        js_calls = f"if(typeof updateDashboard==='function') updateDashboard({json.dumps(fmtR(mo))},{json.dumps(fmtR(td))},{json.dumps(str(len(alerts)))});"
        js_calls += f"if(typeof updateRecentActivity==='function') updateRecentActivity({json.dumps(table_html)});"
        js_calls += f"if(typeof updateChart==='function') updateChart({json.dumps(bars_html)},{json.dumps(labels_html)});"
        QTimer.singleShot(800, lambda: self._run_in_frame(js_calls))


s = {k: v[0] for k, v in parse_qs(u.query).items()}

        if path == "/navigate":
            self._navigate(qs.get("tab", "Dashboard"))
        elif path == "/settings":
            self._open_settings()
        elif path == "/logout":
            self._logout()
        # Route to specific module handlers (simplified bridge)
        elif "/dashboard/" in path: self._handle_dashboard(path, qs)
        elif "/venda/" in path: self._handle_venda(path, qs)
        elif "/produtos/" in path: self._handle_produtos(path, qs)
        elif "/clientes/" in path: self._handle_clientes(path, qs)
        elif "/faltas/" in path: self._handle_faltas(path, qs)
        elif "/trocas/" in path: self._handle_trocas(path, qs)

    def _navigate(self, tab):
        mapping = {
            "Dashboard": "dashboard_theme.html",
            "Nova Venda": "caixa_theme.html",
            "Produtos": "products_theme.html",
            "Historico": "history_theme.html",
            "Clientes": "customers_theme.html",
            "Trocas": "trocas_theme.html",
            "Faltas": "faltas_theme.html",
            "Relatorios": "reports_theme.html",
            "Usuarios": "users_theme.html"
        }
        filename = mapping.get(tab, "dashboard_theme.html")
        file_path = os.path.join(BASE_DIR, filename)
        url = QUrl.fromLocalFile(file_path).toString()
        self.web.page().runJavaScript(f"setFrameUrl('{url}')")
        
        # Auto-refresh logic when entering a page
        QTimer.singleShot(200, lambda: self._refresh_tab(tab))

    def _refresh_current(self):
        # Determine from JS which tab is active (or just refresh everything)
        self.web.page().runJavaScript("currentTab", self._refresh_tab)

    def _refresh_tab(self, tab):
        # Implementation of the injection logic for each module
        if tab == "Dashboard":
            self._inject_dashboard()
        elif tab == "Produtos":
            self._inject_products()
        # ... more injections for all modules ...

    def _open_settings(self):
        dlg = SettingsWebDialog(self, self.dm)
        if dlg.exec_() == QDialog.Accepted:
            self._navigate("Dashboard") # Refresh shell state if needed

    def _logout(self):
        if QMessageBox.question(self, "Sair", "Deseja encerrar o sistema?", QMessageBox.Yes|QMessageBox.No) == QMessageBox.Yes:
            self.close()
            # Re-show login via fresh instance
            self._login_ref = LoginWindow(); self._login_ref.show()
            scr = QApplication.instance().primaryScreen().geometry()
            self._login_ref.move((scr.width()-self._login_ref.width())//2, (scr.height()-self._login_ref.height())//2)

    # --- Module Handlers & Injections (The "Backend" logic) ---
    def _inject_dashboard(self):
        # Move the DashboardTab.refresh logic here
        prods = self.dm.get_products(); sales = self.dm.get_sales(); now = datetime.now()
        td = sum(s.get("total",0) for s in sales if s.get("date","")[:10]==now.strftime("%Y-%m-%d") and s.get("status") != "cancelada")
        mo = sum(s.get("total",0) for s in sales if s.get("date","")[:7]==now.strftime("%Y-%m") and s.get("status") != "cancelada")
        alerts = [p for p in prods if p.get("stock",0)<=p.get("min_stock",0)]
        
        js = f"if(window.updateDashboard) updateDashboard({json.dumps(fmtR(mo))}, {json.dumps(fmtR(td))}, {json.dumps(str(len(alerts)))});"
        self._run_in_frame(js)

    def _run_in_frame(self, js):
        # Execute JS specifically inside the iframe
        full_js = f"document.getElementById('main-frame').contentWindow.eval({json.dumps(js)})"
        self.web.page().runJavaScript(full_js)
